{
  "name": "@uid13/pcm",
  "version": "0.1.0",
  "description": "Personal Computer Manager MCP Service - 个人电脑管家 MCP 服务",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pcm": "dist/index.js"
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "personal-computer",
    "system-management",
    "file-manager",
    "process-manager"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fastmcp": "^4.3.0",
    "sharp": "^0.34.5",
    "systeminformation": "^5.31.7",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.16",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}