{
  "name": "@uid13/pcm",
  "version": "0.3.0",
  "description": "Personal Computer Manager MCP Service - 个人电脑管家 MCP 服务",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pcm": "dist/index.js"
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm clean && pnpm build",
    "prepack": "pnpm build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "personal-computer",
    "system-management",
    "file-manager",
    "process-manager"
  ],
  "author": "uid13",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uid13/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/uid13/mcp/issues"
  },
  "homepage": "https://github.com/uid13/mcp/tree/main/pcm",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "fastmcp": "^4.3.0",
    "puppeteer": "^24.9.0",
    "sharp": "^0.34.5",
    "systeminformation": "^5.31.7",
    "user-agents": "^2.1.94",
    "which": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/which": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.16",
    "vitest": "^1.0.0"
  }
}
